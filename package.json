{
  "name": "infi",
  "version": "1.0.0",
  "description": "Infi — compagnon de révision des étudiants en soins infirmiers (IFSI) : 3 années + mémoire/TFE. PWA hors-ligne.",
  "type": "module",
  "scripts": {
    "serve": "npx serve www -l 5173",
    "dev": "npx serve www -l 5173",
    "check": "find www/js -name '*.js' -print0 | xargs -0 -n1 node --check && node test.mjs",
    "test": "node test.mjs",
    "sync": "npx cap sync android",
    "open": "npx cap open android",
    "icons": "npx capacitor-assets generate --android",
    "deploy:vercel": "npx vercel --prod",
    "deploy:vercel-preview": "npx vercel"
  },
  "dependencies": {
    "@capacitor/android": "^8.0.0",
    "@capacitor/core": "^8.0.0",
    "@capacitor/splash-screen": "^8.0.0",
    "@capacitor/status-bar": "^8.0.0"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.0.0"
  }
}
